# VPS sandbox env template (verification, demo data, no real Oracle).
APP_ENV=local
POSTGRES_DB=mdp
POSTGRES_USER=mdp_user
POSTGRES_PASSWORD=__PG_PWD__
DATABASE_URL=postgresql+psycopg://mdp_user:__PG_PWD__@postgres:5432/mdp
JWT_SECRET_KEY=__JWT__
CONNECTION_SECRET_KEY=__CONN__
MDP_PORT=8457
ORA2PG_CONTAINER=mdpdash_ora2pg

# --- MQTT consumer (default OFF; on the sandbox point at a test mosquitto) ---
MQTT_ENABLED=false
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=1883
MQTT_TOPICS=tipa/hcm/plant1/#
