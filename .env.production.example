# Production template. Copy this file to .env.production and replace every secret.
# Never commit real production secrets.

APP_ENV=production

POSTGRES_DB=mdp
POSTGRES_USER=mdp_user
POSTGRES_PASSWORD=replace_with_strong_password

DATABASE_URL=postgresql+psycopg://mdp_user:replace_with_strong_password@postgres:5432/mdp

JWT_SECRET_KEY=replace_with_very_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

CONNECTION_SECRET_KEY=replace_with_very_long_random_secret_at_least_32_chars

CORS_ORIGINS=["https://your-domain.example.com"]
NEXT_PUBLIC_API_URL=

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace_with_strong_pgadmin_password

# ──────────────────────────────────────────────────────────────────────────────
# Streaming (watermark-incremental) — PRODUCTION SAFETY LOCKS (v0.1.0)
# Ship streaming OFF. Enable per-table from the dashboard ONLY AFTER an admin has
# verified that table's primary key is UNIQUE. High-risk tables that MUST be
# PK-verified first (dashboard shows a "⚠ verify" badge for these):
#   - 4 surrogate/UKID keys: F4111 (ILUKID), F43199 (OLUKID), F3111 (WMUKID), F0030 (AYUKID)
#   - 15 name-mismatch tables (table name differs from JDE vanilla)
# The reference PK is seeded automatically (pk_source=reference); auto-scan is optional.
STREAMING_ENABLED=false
# Background loop tick in seconds (kept long for prod). Per-table cadence is
# poll_interval_sec, whose DB default is already 300s — do not seed dev-fast intervals.
STREAMING_INTERVAL=300

# Oracle source-count refresher OFF in prod (no background COUNT(*) load on Oracle).
ORA2PG_SOURCE_COUNT_ENABLED=false

# This release ships NO MQTT consumer (only MQTT as a connection type). No broker
# loop runs; nothing to disable. (The MDP MQTT consumer lives on a separate branch.)
