# Production template. Copy this file to .env.production and replace every secret.
# Never commit real production secrets.

APP_ENV=production

POSTGRES_DB=mdp
POSTGRES_USER=mdp_user
POSTGRES_PASSWORD=replace_with_strong_password

DATABASE_URL=postgresql+psycopg://mdp_user:replace_with_strong_password@postgres:5432/mdp

JWT_SECRET_KEY=replace_with_very_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

CONNECTION_SECRET_KEY=replace_with_very_long_random_secret_at_least_32_chars

CORS_ORIGINS=["https://your-domain.example.com"]
NEXT_PUBLIC_API_URL=

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace_with_strong_pgadmin_password
