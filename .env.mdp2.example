# tipa-vm DEV `mdp2` env template (streaming-watermark feature build → local ora-free Oracle).
# Copy to .env.mdp2 on the VM, fill REAL secrets (>=32 random), chmod 600. NEVER commit .env.mdp2.
APP_ENV=production
POSTGRES_DB=mdp
POSTGRES_USER=mdp_user
POSTGRES_PASSWORD=__PG_PWD__
DATABASE_URL=postgresql+psycopg://mdp_user:__PG_PWD__@postgres:5432/mdp
JWT_SECRET_KEY=__JWT_32+__
CONNECTION_SECRET_KEY=__CONN_32+__
CORS_ORIGINS=["http://127.0.0.1:8456","http://172.17.1.153:8456"]
MDP_PORT=8456
ORA2PG_CONTAINER=mdp2_ora2pg

# Oracle = local ora-free sandbox (host resolves once ora-free joins mdp2_default).
ORACLE_HOST=ora-free
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=FREEPDB1
ORACLE_SID=
ORACLE_USER=tipa_esb
ORACLE_PWD=__FROM_~/.orafree_pw__
ORACLE_SCHEMA=MDPVW

# Background loops — default OFF. Streaming run-once works regardless; flip to true to test the loop.
ORA2PG_SOURCE_COUNT_ENABLED=false
STREAMING_ENABLED=false
STREAMING_INTERVAL=60
