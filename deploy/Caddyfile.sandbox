# VPS sandbox — plain HTTP on :8457 (verification only; coexists with mdp/mdp2/mdp3).
:8457 {
	encode gzip

	handle_path /api/* {
		reverse_proxy backend:8000
	}
	handle /docs* {
		reverse_proxy backend:8000
	}
	handle /openapi.json {
		reverse_proxy backend:8000
	}
	handle {
		reverse_proxy frontend:3000
	}
}
