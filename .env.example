# Local development only. Do not use these demo defaults in production.
# For cloud deployment, copy .env.production.example to .env.production and set real secrets.
APP_ENV=local

POSTGRES_DB=mdp
POSTGRES_USER=mdp_user
POSTGRES_PASSWORD=mdp_password

DATABASE_URL=postgresql+psycopg://mdp_user:mdp_password@postgres:5432/mdp
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional host port overrides if local ports are already in use.
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000
PGADMIN_PORT=5050

JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CONNECTION_SECRET_KEY=change_me_connection_secret_key

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
