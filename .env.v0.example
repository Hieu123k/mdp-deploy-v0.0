# MDP-deploy v0.0 production env template (copy to .env.production; never commit real values).
APP_ENV=production
POSTGRES_DB=mdp
POSTGRES_USER=mdp_user
POSTGRES_PASSWORD=change_me_strong
DATABASE_URL=postgresql+psycopg://mdp_user:change_me_strong@postgres:5432/mdp
JWT_SECRET_KEY=replace_with_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CONNECTION_SECRET_KEY=replace_with_long_random_secret_at_least_32_chars
CORS_ORIGINS=["https://your-mdp-host"]
NEXT_PUBLIC_API_URL=

# --- ora2pg Migration Dashboard (Oracle JDE source; only reachable on .63) ---
ORA2PG_IMAGE=georgmoser/ora2pg:24.3
ORA2PG_CONTAINER=tipa_ora2pg
ORA2PG_TARGET_SCHEMA=mdp_staging
ORACLE_HOST=your-oracle-host
ORACLE_PORT=1521
ORACLE_SID=your_sid
ORACLE_SERVICE_NAME=
ORACLE_USER=your_oracle_user
ORACLE_PWD=your_oracle_password
ORACLE_SCHEMA=SYSTEM
