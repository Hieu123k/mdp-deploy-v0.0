# ora2pg kit credentials — copy this file to .env and fill in REAL values.
# .env is gitignored; NEVER commit real secrets.

# Oracle source (JDE)
ORACLE_HOST=oracle-host-or-ip
ORACLE_SID=YOUR_SID
ORACLE_PORT=1521
ORACLE_USER=oracle_user
ORACLE_PWD=change_me

# PostgreSQL target (uns_db mirror)
PG_HOST=pg-host-or-ip
PG_PORT=5434
PG_DBNAME=uns_db
PG_USER=pg_user
PG_PWD=change_me
